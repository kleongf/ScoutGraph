# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Firebase Admin SDK (server-side) ───────────────────────────────────────────
# Copy these three values from your serviceAccountKey.json, then delete the file.
# project_id → FIREBASE_PROJECT_ID
# client_email → FIREBASE_CLIENT_EMAIL
# private_key → FIREBASE_PRIVATE_KEY  (paste exactly as-is, including \n characters)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Firebase Client SDK (VITE_ prefix → available in browser) ──────────────────
# Copy from Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── App defaults ───────────────────────────────────────────────────────────────
VITE_DEFAULT_EVENT_KEY=2026caven
